<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:orientation="vertical"
    android:background="#E6DBAE">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Supplies:"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:textSize="40dp"
        android:paddingBottom="20dp"
        android:textColor="#590606"
        android:layout_gravity="center"

        />

    <Button
        android:id="@+id/product_saveBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Zapisz zmiany"
        android:backgroundTint="#590606"
        android:layout_gravity="center"
        />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wybierz kategorię:"
        android:textSize="25dp"
        android:gravity="center"
        android:textColor="#590606"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        >

        <Spinner
            android:id="@+id/category_spinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center">

        <Button
            android:id="@+id/product_increaseQuantity"
            android:backgroundTint="#590606"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+1 Quantity"
            />

        <EditText
            android:id="@+id/product_search"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:hint="Wyszukaj"
            android:textColor="#590606"
            android:layout_marginHorizontal="15dp"
            android:textAlignment="center"
            />

        <Button
            android:id="@+id/product_decreaseQuantity"
            android:backgroundTint="#590606"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-1 Quantity"/>

    </LinearLayout>

    <ListView
        android:id="@+id/ListOfProducts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        />

</LinearLayout>